COMPOSIO_API_KEY=
GITHUB_AUTH_CONFIG_ID=
NOTION_AUTH_CONFIG_ID=
GMAIL_AUTH_CONFIG_ID=
GOOGLECALENDAR_AUTH_CONFIG_ID=
# Do NOT set COMPOSIO_BASE_URL. The @composio/core SDK reads this env var and
# breaks if it points at a versioned REST path (e.g. /api/v3.1), returning 404s.
# The REST routes default to the correct base via lib/config.js.
# COMPOSIO_BASE_URL=https://backend.composio.dev/api/v3.1

# Neon Postgres connection string (Prisma). Get it from the Neon dashboard.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Auth.js (NextAuth) secret. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Required so Auth.js trusts the host behind ngrok / Vercel proxies.
AUTH_TRUST_HOST=true

# Optional — local ngrok dev origin for Next.js cross-origin (comma-separated).
# ALLOWED_DEV_ORIGINS=https://your-subdomain.ngrok-free.dev
